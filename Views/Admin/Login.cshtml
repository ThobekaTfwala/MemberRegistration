@model MeetingRegister.Models.AdminLoginViewModel

@{
    ViewData["Title"] = "Admin Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-4">
                    <h3 class="mb-0 font-weight-light"><i class="bi bi-shield-lock me-2"></i>Admin Portal</h3>
                </div>
                <div class="card-body p-4">
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <div asp-validation-summary="All" class="text-danger mb-0"></div>
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Username" class="form-control" placeholder="admin" autofocus />
                            <label asp-for="Username"></label>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Password" class="form-control" placeholder="password" />
                            <label asp-for="Password"></label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg">Login</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
